{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "feedback.schema.json",
  "title": "Persona feedback report",
  "type": "object",
  "required": ["persona_id", "target", "task", "outcome", "findings"],
  "properties": {
    "persona_id": { "type": "string" },
    "target": { "type": "string", "format": "uri" },
    "task": { "type": "string" },
    "started_at": { "type": "string", "format": "date-time" },
    "duration_seconds": { "type": "number", "minimum": 0 },
    "outcome": {
      "enum": ["completed", "abandoned", "blocked", "error"]
    },
    "narrative": {
      "type": "string",
      "description": "ペルソナ視点での一人称ナレーション"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "severity", "description"],
        "properties": {
          "category": {
            "enum": ["usability", "bug", "accessibility", "copywriting", "performance", "trust"]
          },
          "severity": { "enum": ["low", "medium", "high", "critical"] },
          "location": {
            "type": "string",
            "description": "URL or DOM selector / region"
          },
          "description": { "type": "string" },
          "quote": {
            "type": "string",
            "description": "ペルソナの生の声（一人称）"
          },
          "screenshot": { "type": "string" },
          "suggestion": { "type": "string" }
        }
      }
    },
    "score": {
      "type": "object",
      "properties": {
        "overall": { "type": "number", "minimum": 0, "maximum": 10 },
        "would_recommend": { "type": "boolean" }
      }
    },
    "action_log": {
      "type": "array",
      "description": "Time-stamped action trace recorded by persona-runner. Drives behavior_metrics computation in aggregate.mjs.",
      "items": {
        "type": "object",
        "required": ["at_seconds", "action"],
        "additionalProperties": false,
        "properties": {
          "at_seconds": {
            "type": "number",
            "minimum": 0,
            "description": "Seconds since started_at."
          },
          "action": {
            "enum": [
              "navigate",
              "snapshot",
              "click",
              "type",
              "select",
              "press_key",
              "scroll",
              "wait",
              "back",
              "cancel",
              "screenshot",
              "give_up"
            ]
          },
          "target_desc": {
            "type": "string",
            "description": "Human-readable description of the element / URL acted upon (e.g. 'メアド入力欄', 'http://x/login')."
          },
          "location": {
            "type": "string",
            "description": "Logical screen identifier, e.g. URL or step name. Used to compute time-on-screen and back/cancel rate per screen."
          },
          "note": {
            "type": "string",
            "description": "Optional free-text annotation (e.g. '迷った', '戻った')."
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "outcome": { "enum": ["abandoned", "blocked", "error"] } },
        "required": ["outcome"]
      },
      "then": {
        "properties": {
          "findings": { "minItems": 1 }
        }
      }
    }
  ]
}
